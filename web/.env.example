# ============================================================
# ISO Drums — Web API environment variables
# Copy this file to .env.local for local development.
# Set these as Environment Variables in your Vercel project.
# ============================================================

# Vercel KV (Upstash Redis)
# Provisioned automatically when you add a KV store in the
# Vercel dashboard (Storage → Connect Store).
KV_REST_API_URL=https://YOUR_KV_ENDPOINT.upstash.io
KV_REST_API_TOKEN=YOUR_KV_TOKEN

# Resend — transactional email (https://resend.com)
# Create a free account, add your domain, and paste the API key here.
RESEND_API_KEY=re_YOUR_API_KEY

# Sender address (must match a verified domain in Resend)
FROM_EMAIL=ISO Drums <licenses@isodrums.com>

# LemonSqueezy webhook signing secret
# Settings → Webhooks → your webhook → Signing Secret
LEMONSQUEEZY_WEBHOOK_SECRET=your_lemonsqueezy_signing_secret
